{
  "name": "remark-dgmo",
  "version": "0.5.0",
  "description": "Remark plugin to render DGMO diagrams from fenced code blocks at build time. Framework-agnostic core shared by astro-dgmo, docusaurus-plugin-dgmo, and any unified pipeline.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diagrammo/remark-dgmo.git"
  },
  "homepage": "https://github.com/diagrammo/remark-dgmo#readme",
  "bugs": {
    "url": "https://github.com/diagrammo/remark-dgmo/issues"
  },
  "keywords": [
    "remark",
    "remark-plugin",
    "mdast",
    "unified",
    "dgmo",
    "diagrammo",
    "diagram",
    "diagrams",
    "mdx",
    "markdown",
    "astro",
    "docusaurus",
    "starlight",
    "color-mode"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./remark": {
      "types": "./dist/remark-plugin.d.ts",
      "import": "./dist/remark-plugin.js",
      "default": "./dist/remark-plugin.js"
    },
    "./client.js": "./dist/client.js",
    "./client.css": "./dist/client.css",
    "./theme-nord.css": "./dist/theme-nord.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.6"
  },
  "scripts": {
    "build": "tsup && cp styles/client.css dist/client.css && cp styles/theme-nord.css dist/theme-nord.css",
    "postbuild": "test -f dist/client.css && test -f dist/client.js && test -f dist/theme-nord.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:deadcode": "knip",
    "check:duplication": "jscpd ./src",
    "check:deps": "depcheck --ignores=''",
    "check:all": "pnpm check:deadcode && pnpm check:duplication && pnpm check:deps",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "peerDependencies": {
    "@diagrammo/dgmo": "^0.45.0"
  },
  "dependencies": {
    "@lezer/common": "^1.5.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.8",
    "estree-util-value-to-estree": "^3.5.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@diagrammo/dgmo": "^0.45.0",
    "@eslint/js": "^10.0.1",
    "@mdx-js/mdx": "^3.1.0",
    "@types/estree": "^1.0.8",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.6",
    "depcheck": "^1.4.7",
    "eslint": "^10.4.0",
    "jscpd": "^4.0.9",
    "knip": "^6.14.1",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.4"
  }
}
